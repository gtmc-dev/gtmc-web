{
  "name": "gtmc-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "pnpm lint:fix",
    "lint:fix": "eslint --fix && prettier --write .",
    "lint:check": "prettier --check . && eslint",
    "postinstall": "prisma generate && pnpm articles:init && pnpm articles:update && pnpm generate-slug-map",
    "generate-slug-map": "tsx scripts/generate-slug-map.ts",
    "articles:init": "git submodule update --init --recursive",
    "articles:update": "git submodule update --remote articles",
    "articles:status": "git submodule status articles",
    "analyze": "ANALYZE=true pnpm build",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@fontsource/space-mono": "^5.2.9",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "7.6.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.2",
    "@vercel/speed-insights": "^2.0.0",
    "browser-image-compression": "^2.0.2",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.44",
    "mime-types": "^3.0.2",
    "minisearch": "^7.2.0",
    "motion": "^12.38.0",
    "next": "16.2.2",
    "next-auth": "5.0.0-beta.30",
    "node-diff3": "^3.2.0",
    "pangu": "^7.2.1",
    "prisma": "7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "shiki": "^4.0.2",
    "strip-markdown": "^6.0.0",
    "undici": "^7.24.6",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/diff": "^8.0.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "playwright": "^1.59.1",
    "pnpm": "^10.33.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "resolutions": {
    "form-data": "4.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "form-data": "4.0.5"
    }
  }
}
