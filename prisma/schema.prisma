generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. Auth.js (NextAuth) 鏍囧噯璐︽埛浣撶郴涓庢墿锟?
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER")
  githubPat     String?


  accounts      Account[]
  sessions      Session[]

  articles      Article[]  @relation("ArticleAuthor")
  revisions     Revision[] @relation("RevisionAuthor")
  reviews       Revision[] @relation("RevisionReviewer")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 3. 鏍稿績涓氬姟锛氭枃绔犱笌鐗堟湰鍗忓悓鎺у埗浣撶郴
// ==========================================

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  coverImage  String?
  
  authorId    String
  author      User     @relation("ArticleAuthor", fields: [authorId], references: [id])

  revisions   Revision[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Revision {
  id          String         @id @default(cuid())
  title       String
  content     String
  coverImage  String?
  
  status      String         @default("DRAFT")
  reviewNote  String?
  filePath    String?

  articleId   String?
  article     Article?       @relation(fields: [articleId], references: [id], onDelete: SetNull)

  authorId    String
  author      User           @relation("RevisionAuthor", fields: [authorId], references: [id])

  reviewerId  String?
  reviewer    User?          @relation("RevisionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}



